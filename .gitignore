# ==============================
# Python 虚拟环境与依赖
# ==============================
.venv/
.cvenv/
env/
ENV/

# ==============================
# Python 字节码与缓存
# ==============================
__pycache__/
*.py[cod]      # 匹配 .pyc, .pyo, .pyd 等
*.pyc
*.pyo
*.pyd

# ==============================
# 构建与分发产物
# ==============================
build/
dist/
*.egg-info/
*.spec

# ==============================
# 日志与报告（运行时生成）
# ==============================
*.log
logs/
reports/

# ==============================
# 测试与覆盖率
# ==============================
.pytest_cache/
.coverage
htmlcov/

# ==============================
# IDE / 编辑器文件
# ==============================
.vscode/
.idea/
*.swp
.DS_Store

# ==============================
# 压缩包（避免误提交临时打包文件）
# ==============================
*.zip
*.tar.gz
*.7z
*.rar

# ==============================
# MT5 特定忽略项
# ==============================
/mql5/*.ex5       # 编译后的 EA，应由 .mq5 源码重新生成
!mql5/            # 保留 mql5 目录本身（确保能 git clone 后看到结构）

# ==============================
# 环境变量（敏感信息）
# ==============================
.env
.env.local
.env.*.local
/build
